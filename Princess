.toothless-wrap {
  position: relative;
  width: 160px;
  height: 160px;
}

.tooth-body {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  width: 70px;
  height: 60px;
  background: #1a1a2a;
  border-radius: 30px 30px 20px 20px;
  border: 2px solid #0a0a15;
  animation: toothlessWiggle 2s ease-in-out infinite;
}

@keyframes toothlessWiggle {
  0%,100% { transform: translateX(-50%) rotate(-1deg); }
  50% { transform: translateX(-50%) rotate(1deg); }
}

.tooth-wing {
  position: absolute;
  bottom: 30px;
  width: 44px;
  height: 50px;
  background: #1a1a2a;
  border: 2px solid #0a0a15;
  border-radius: 40% 60% 20% 80%;
}

.tooth-wing.left {
  left: 8px;
  transform: rotate(-20deg);
  transform-origin: bottom right;
  animation: wingFlapLeft 1.5s ease-in-out infinite;
}

.tooth-wing.right {
  right: 8px;
  transform: rotate(20deg) scaleX(-1);
  transform-origin: bottom left;
  animation: wingFlapRight 1.5s ease-in-out infinite;
}

@keyframes wingFlapLeft {
  0%,100% { transform: rotate(-20deg); }
  50% { transform: rotate(-35deg); }
}

@keyframes wingFlapRight {
  0%,100% { transform: rotate(20deg) scaleX(-1); }
  50% { transform: rotate(35deg) scaleX(-1); }
}

.tooth-tail {
  position: absolute;
  bottom: 14px;
  right: 4px;
  width: 36px;
  height: 14px;
  background: #1a1a2a;
  border-radius: 0 8px 8px 0;
  border: 2px solid #0a0a15;
}

.tooth-tail::after {
  content: '';
  position: absolute;
  right: -4px;
  top: -6px;
  width: 14px;
  height: 12px;
  background: #cc3300;
  border-radius: 6px 8px 4px 6px;
  transform: rotate(15deg);
}

.tooth-head {
  position: absolute;
  bottom: 74px;
  left: 50%;
  transform: translateX(-50%);
  width: 68px;
  height: 56px;
  background: #1a1a2a;
  border-radius: 44% 44% 36% 36%;
  border: 2px solid #0a0a15;
  animation: toothlessHead 3s ease-in-out infinite;
}

@keyframes toothlessHead {
  0%,100% { transform: translateX(-50%) rotate(0deg); }
  40% { transform: translateX(-50%) rotate(-4deg); }
  70% { transform: translateX(-50%) rotate(3deg); }
}

.tooth-eyes-row {
  position: absolute;
  top: 14px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 14px;
}

.tooth-eye {
  width: 18px;
  height: 18px;
  background: #00cc88;
  border-radius: 50%;
  border: 2px solid #009966;
  position: relative;
  animation: toothEyeGlow 2s ease-in-out infinite;
}

@keyframes toothEyeGlow {
  0%,100% { box-shadow: 0 0 6px #00cc88; }
  50% { box-shadow: 0 0 14px #00ffaa; }
}

.tooth-pupil {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  width: 8px;
  height: 14px;
  background: #111;
  border-radius: 50%;
  animation: toothPupilSlit 3s ease-in-out infinite;
}

@keyframes toothPupilSlit {
  0%,100% { width: 8px; }
  50% { width: 12px; }
}

.tooth-ear {
  position: absolute;
  top: -10px;
  width: 14px;
  height: 18px;
  background: #1a1a2a;
  border: 2px solid #0a0a15;
  border-radius: 50% 50% 0 0;
}

.tooth-ear.left { left: 10px; transform: rotate(-15deg); }
.tooth-ear.right { right: 10px; transform: rotate(15deg); }

.tooth-smile {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 28px;
  height: 12px;
  border-bottom: 3px solid #444;
  border-radius: 0 0 14px 14px;
}

.tooth-legs { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); display: flex; gap: 14px; }
.tooth-leg { width: 16px; height: 22px; background: #1a1a2a; border: 2px solid #0a0a15; border-radius: 4px 4px 8px 8px; }
.tooth-claw { display: flex; gap: 2px; margin-top: -2px; }
.tooth-claw-toe { width: 5px; height: 7px; background: #333; border-radius: 2px 2px 4px 4px; }

.tooth-fire {
  position: absolute;
  top: 6px;
  right: 8px;
  font-size: 22px;
  animation: firePulse 0.8s ease-in-out infinite;
}

@keyframes firePulse {
  0%,100% { transform: scale(1) rotate(-5deg); }
  50% { transform: scale(1.2) rotate(5deg); }
}

