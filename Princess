<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>He's Sorry, Princess 💗</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@300;400;600&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
  --pink: #ff8fab;
  --light-pink: #ffc8dd;
  --soft: #fff0f5;
  --deep: #c9184a;
  --yellow: #ffd166;
  --sky: #a8daff;
  --mint: #b7e4c7;
  --lavender: #cdb4db;
  --bg: #fff5f8;
}

body {
  background: var(--bg);
  font-family: 'Nunito', sans-serif;
  overflow-x: hidden;
  min-height: 100vh;
}

/* Floating hearts background */
.bg-hearts {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.bg-heart {
  position: absolute;
  font-size: var(--s);
  animation: floatHeart var(--d) ease-in-out infinite;
  opacity: 0;
  bottom: -40px;
}

@keyframes floatHeart {
  0% { transform: translateY(0) rotate(0deg) scale(0.5); opacity: 0; }
  15% { opacity: 0.6; }
  85% { opacity: 0.3; }
  100% { transform: translateY(-110vh) rotate(20deg) scale(1); opacity: 0; }
}

/* Header */
.hero {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 52px 24px 24px;
  animation: fadeDown 1s ease both;
}

@keyframes fadeDown {
  from { opacity:0; transform: translateY(-30px); }
  to { opacity:1; transform: translateY(0); }
}

.hero .tag {
  display: inline-block;
  background: var(--pink);
  color: white;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 20px;
  margin-bottom: 18px;
  font-family: 'Nunito', sans-serif;
  font-weight: 600;
}

.hero h1 {
  font-family: 'Dancing Script', cursive;
  font-size: clamp(2.6rem, 8vw, 4.5rem);
  color: var(--deep);
  line-height: 1.1;
  margin-bottom: 12px;
}

.hero p {
  font-size: 1rem;
  color: #b5688a;
  font-weight: 300;
  max-width: 400px;
  margin: 0 auto;
  line-height: 1.6;
}

/* Cards grid */
.cards {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 900px;
  margin: 40px auto;
  padding: 0 24px;
}

.card {
  background: white;
  border-radius: 28px;
  padding: 32px 24px 28px;
  box-shadow: 0 8px 32px rgba(201,24,74,0.08);
  border: 2px solid rgba(255,143,171,0.2);
  text-align: center;
  animation: cardPop 0.7s cubic-bezier(0.34,1.56,0.64,1) both;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  position: relative;
  overflow: hidden;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: 0 16px 48px rgba(201,24,74,0.15);
}

.card:nth-child(1) { animation-delay: 0.1s; }
.card:nth-child(2) { animation-delay: 0.25s; }
.card:nth-child(3) { animation-delay: 0.4s; }
.card:nth-child(4) { animation-delay: 0.55s; }
.card:nth-child(5) { animation-delay: 0.7s; }

@keyframes cardPop {
  from { opacity:0; transform: scale(0.7) translateY(20px); }
  to { opacity:1; transform: scale(1) translateY(0); }
}

.card .corner-heart {
  position: absolute;
  top: 14px;
  right: 16px;
  font-size: 20px;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%,100% { transform: scale(1); }
  50% { transform: scale(1.25); }
}

/* SVG character scene */
.char-scene {
  width: 160px;
  height: 160px;
  margin: 0 auto 16px;
}

.card h2 {
  font-family: 'Fredoka One', cursive;
  font-size: 1.3rem;
  color: var(--deep);
  margin-bottom: 6px;
}

.card .sorry-quote {
  font-size: 0.88rem;
  color: #b5688a;
  font-style: italic;
  line-height: 1.5;
  font-weight: 400;
}

/* Bottom message */
.bottom-msg {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 20px 24px 60px;
  animation: fadeUp 1s ease 1s both;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(20px); }
  to { opacity:1; transform:translateY(0); }
}

.bottom-msg .big-text {
  font-family: 'Dancing Script', cursive;
  font-size: clamp(1.8rem, 6vw, 3rem);
  color: var(--deep);
  margin-bottom: 10px;
}

.bottom-msg .sub {
  font-size: 0.95rem;
  color: #b5688a;
  font-weight: 300;
}

.hearts-bounce {
  font-size: 2rem;
  margin-top: 14px;
  display: flex;
  justify-content: center;
  gap: 10px;
}

.hearts-bounce span {
  display: inline-block;
  animation: heartJump 1.2s ease-in-out infinite;
}

.hearts-bounce span:nth-child(2) { animation-delay: 0.2s; }
.hearts-bounce span:nth-child(3) { animation-delay: 0.4s; }

@keyframes heartJump {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}


@keyframes snowDrift {
  0%,100% { transform: translateY(0) rotate(0deg); opacity: 0.3; }
  50% { transform: translateY(-8px) rotate(20deg); opacity: 0.5; }
}

@keyframes yygArm {
  0%,100% { transform: rotate(-20deg); }
  50% { transform: rotate(-35deg); }
}

@keyframes yygHead {
  0%,100% { transform: translateX(-50%) rotate(0deg); }
  40% { transform: translateX(-50%) rotate(-3deg); }
  70% { transform: translateX(-50%) rotate(3deg); }
}

